# ColourSense API environment variables.
# Copy to .env for local development. NEVER commit real values.

# development | test | production
APP_ENV=development
APP_NAME=coloursense-api
APP_VERSION=0.1.0

# Bind address for local runs (Render supplies its own).
API_HOST=127.0.0.1
API_PORT=8000

# Exact origin of the frontend, used for CORS (no trailing slash).
FRONTEND_URL=http://localhost:3000

# Supabase project (Settings → API). The service-role key and JWT secret are
# server-side secrets: never expose them to a browser or commit them.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Legacy HS256 JWT secret (Settings → API → JWT). Leave empty on projects that
# use asymmetric JWT signing keys — the API then verifies via the JWKS endpoint.
SUPABASE_JWT_SECRET=

# PostgreSQL connection string. Local development uses the docker-compose
# database; production uses the Supabase pooler URI (postgresql+asyncpg://...).
DATABASE_URL=postgresql+asyncpg://coloursense:coloursense@localhost:54329/coloursense

# Upload limit in megabytes (enforced before decoding).
MAX_IMAGE_SIZE_MB=10

# Master switch for the optional "save my analysis image" feature.
IMAGE_STORAGE_ENABLED=true

# Rate limit applied to the expensive analysis endpoints (slowapi syntax).
RATE_LIMIT=10/minute

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Optional override; defaults to packages/colour-engine/config/classifier-v1.json
# in the repo, or /app/config/classifier-v1.json inside the container.
# CLASSIFIER_CONFIG_PATH=
